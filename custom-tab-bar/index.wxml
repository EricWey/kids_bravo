<view class="tab-shell" style="padding-bottom: {{safeBottom}}px;">
  <view class="tab-list">
    <view wx:for="{{tabs}}" wx:key="pagePath" class="tab-item {{selected === index ? 'active' : ''}}" data-index="{{index}}" bindtap="switchTab">
      <view class="tab-icon">{{item.icon}}</view>
      <view class="tab-text" style="font-size: {{fontSize}}px;">{{item.text}}</view>
    </view>
  </view>
</view>
