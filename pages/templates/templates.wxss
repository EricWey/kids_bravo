.filters {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.picker-field {
  display: flex;
  align-items: center;
}

.gender-switch {
  display: flex;
  position: relative;
  padding: 8rpx;
  border-radius: 999rpx;
  background: #fff6d8;
}

.gender-switch button {
  display: flex;
  position: relative;
  z-index: 1;
  flex: 1;
  min-height: 70rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #7c6b55;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1;
  transition: color 240ms ease;
}

.gender-switch button::after {
  border: 0;
}

.gender-switch .active {
  color: #453010;
}

.gender-indicator {
  position: absolute;
  top: 8rpx;
  bottom: 8rpx;
  left: 8rpx;
  width: calc((100% - 16rpx) / 2);
  border-radius: 999rpx;
  background: #ffca54;
  box-shadow: 0 8rpx 18rpx rgba(255, 162, 61, 0.18);
  transition: transform 240ms ease;
}

.gender-indicator.right {
  transform: translateX(100%);
}

.template-card {
  margin-top: 20rpx;
}

.template-title {
  font-size: 32rpx;
  font-weight: 900;
}

.small {
  min-width: 140rpx;
  min-height: 66rpx;
  font-size: 24rpx;
}

.category-block {
  margin-top: 22rpx;
}

.category-title {
  margin-bottom: 10rpx;
  color: #2f8c72;
  font-size: 28rpx;
  font-weight: 900;
}

.task-preview {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 2rpx dashed #f1e0bf;
  font-size: 26rpx;
}
