.badge-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.badge {
  min-height: 210rpx;
  text-align: center;
  opacity: 0.58;
}

.badge.unlocked {
  border-color: #84dfa3;
  opacity: 1;
}

.badge-icon {
  font-size: 48rpx;
}

.badge-name {
  margin: 12rpx 0 8rpx;
  font-size: 29rpx;
  font-weight: 900;
}
