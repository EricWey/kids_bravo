<view class="page">
  <view class="hero">
    <view class="hero-title">成长成就</view>
    <view class="hero-subtitle">把每天的小努力，换成看得见的成长勋章。</view>
  </view>

  <view class="section-title">成长徽章</view>
  <view class="badge-grid">
    <view wx:for="{{badges}}" wx:key="key" class="card badge {{item.unlocked ? 'unlocked' : ''}}">
      <view class="badge-icon">{{item.icon}}</view>
      <view class="badge-name">{{item.name}}</view>
      <view class="muted">{{item.description}}</view>
    </view>
  </view>
</view>
