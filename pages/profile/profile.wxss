.profile-section {
  position: relative;
  margin-top: 34rpx;
  padding-bottom: 78rpx;
}

.profile-section-title {
  display: block;
  width: 100%;
  margin: 0 4rpx 18rpx;
  color: #493d31;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
  text-align: left;
  white-space: nowrap;
  writing-mode: horizontal-tb;
}

.profile-actions {
  display: flex;
  position: absolute;
  left: 0;
  bottom: 0;
  align-items: center;
  gap: 10rpx;
}

.icon-hit {
  display: flex;
  width: 64rpx;
  height: 64rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: transparent;
}

.icon-hit:active .icon-dot {
  transform: scale(0.86);
  filter: brightness(0.96);
}

.icon-dot {
  display: flex;
  width: 48rpx;
  height: 48rpx;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(78, 58, 22, 0.1);
  border-radius: 50%;
  color: #5b430f;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1;
  background: #ffe28f;
  box-shadow: inset 0 2rpx 2rpx rgba(255, 255, 255, 0.58), 0 4rpx 10rpx rgba(79, 56, 18, 0.08);
  transition: transform 120ms ease, filter 120ms ease, box-shadow 120ms ease;
}

.refresh-button .icon-dot {
  color: #6b4b10;
  font-size: 25rpx;
  background: #ffd96c;
}

.add-profile-button .icon-dot {
  color: #fff;
  font-size: 30rpx;
  background: #35c3aa;
  border-color: rgba(20, 128, 111, 0.18);
}

.child-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.swipe-row {
  position: relative;
  overflow: hidden;
  border-radius: 20rpx;
}

.child-card {
  display: flex;
  position: relative;
  z-index: 1;
  min-height: 150rpx;
  align-items: stretch;
  gap: 0;
  padding: 0;
  overflow: hidden;
  transition: transform 180ms ease;
}

.child-card.active {
  border-color: #ffb84d;
  background: #fff8df;
}

.card-action {
  display: flex;
  align-self: stretch;
  flex: 0 0 25%;
  width: 25%;
  min-width: 0;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  border-radius: 0 16rpx 16rpx 0;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.25;
  text-align: center;
  transition: transform 160ms ease, filter 160ms ease, background 160ms ease;
}

.card-action-hover {
  transform: scale(0.98);
  filter: brightness(0.98);
}

.detail-button {
  color: #fff8cdf2;
  background: #e8ab03;
}

.switch-button {
  color: #2e6f7f;
  background: #dff7ff;
}

.child-avatar {
  display: flex;
  flex: 0 0 84rpx;
  width: 84rpx;
  height: 84rpx;
  margin: auto 22rpx auto 26rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #45c4b0, #53a7ff);
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.child-info {
  flex: 1;
  min-width: 0;
  padding: 24rpx 12rpx 24rpx 0;
}

.child-name {
  margin-bottom: 8rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.avatar-hint {
  margin-top: 8rpx;
  color: #2d8a72;
  font-size: 22rpx;
}

.delete-action {
  display: flex;
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 150rpx;
  align-items: center;
  justify-content: center;
  border-radius: 0 20rpx 20rpx 0;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  background: #ef5757;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.field-group {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.field-label {
  color: #5d5144;
  font-size: 26rpx;
  font-weight: 900;
}

.picker-field {
  display: flex;
  align-items: center;
}

.gender-switch {
  display: flex;
  position: relative;
  padding: 8rpx;
  border-radius: 999rpx;
  background: #fff6d8;
}

.gender-option {
  display: flex;
  position: relative;
  z-index: 1;
  flex: 1;
  min-height: 68rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #7c6b55;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1;
  transition: color 240ms ease;
}

.gender-switch .active {
  color: #453010;
}

.gender-indicator {
  position: absolute;
  top: 8rpx;
  bottom: 8rpx;
  left: 8rpx;
  width: calc((100% - 16rpx) / 2);
  border-radius: 999rpx;
  background: #ffca54;
  box-shadow: 0 8rpx 18rpx rgba(255, 162, 61, 0.18);
  transition: transform 240ms ease;
}

.gender-indicator.right {
  transform: translateX(100%);
}

.quick-actions {
  margin-top: 24rpx;
}

.modal-mask {
  display: flex;
  position: fixed;
  inset: 0;
  z-index: 120;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(55, 42, 23, 0.34);
}

.profile-modal {
  width: 100%;
  max-width: 650rpx;
  max-height: calc(100vh - 128rpx);
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fffdf5;
  box-shadow: 0 18rpx 50rpx rgba(60, 39, 12, 0.18);
}

.modal-title {
  margin-bottom: 24rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.modal-title.compact {
  margin-bottom: 6rpx;
}

.modal-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.close-button {
  display: flex;
  width: 52rpx;
  height: 52rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #6a5b49;
  font-size: 34rpx;
  font-weight: 700;
  background: #f7edd3;
}

.task-modal {
  width: 100%;
  max-width: 680rpx;
  max-height: calc(100vh - 128rpx);
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fffdf5;
  box-shadow: 0 18rpx 50rpx rgba(60, 39, 12, 0.18);
}

.task-detail-list {
  display: flex;
  max-height: 62vh;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 22rpx;
  overflow-y: auto;
}

.task-swipe-row {
  position: relative;
  overflow: hidden;
  border-radius: 18rpx;
}

.task-actions-menu {
  display: flex;
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 192rpx;
}

.task-menu-button {
  display: flex;
  width: 96rpx;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
}

.task-menu-button.edit {
  background: #45c4b0;
}

.task-menu-button.delete {
  background: #ef5757;
}

.task-detail-card {
  position: relative;
  z-index: 1;
  padding: 18rpx;
  border: 3rpx solid #ffefbf;
  border-radius: 18rpx;
  background: #fffaf0;
  transition: transform 180ms ease;
}

.task-detail-title {
  font-size: 28rpx;
  font-weight: 900;
}

.task-detail-desc {
  margin-top: 8rpx;
  color: #756653;
  font-size: 24rpx;
  line-height: 1.35;
}

.task-meta-row {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 10rpx;
  color: #2f8c72;
  font-size: 23rpx;
  font-weight: 800;
}

.task-created {
  margin-top: 10rpx;
  color: #8a7a65;
  font-size: 22rpx;
}

.small-empty {
  margin-top: 22rpx;
  padding: 32rpx 20rpx;
}

.task-editor {
  width: 100%;
  max-width: 680rpx;
  max-height: calc(100vh - 128rpx);
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fffdf5;
  box-shadow: 0 18rpx 50rpx rgba(60, 39, 12, 0.18);
}

.compact-textarea {
  min-height: 112rpx;
}

.avatar-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
}
