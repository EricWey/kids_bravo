<view class="page">
  <view class="hero">
    <view class="hero-title">Bravo 星球</view>
    <view class="hero-subtitle">今天就把好习惯变成闪亮金币！</view>
  </view>

  <view class="profile-section">
    <view class="profile-section-title">小朋友档案</view>

    <view class="profile-actions">
      <button class="icon-hit refresh-button" aria-label="刷新档案" bindtap="reload">
        <text class="icon-dot">↻</text>
      </button>
      <button class="icon-hit add-profile-button" aria-label="新增档案" bindtap="openCreateModal">
        <text class="icon-dot">+</text>
      </button>
    </view>

    <view wx:if="{{children.length}}" class="child-list">
      <view wx:for="{{children}}" wx:key="_id" class="swipe-row">
        <view class="delete-action" data-id="{{item._id}}" data-name="{{item.nickname}}" bindtap="confirmDelete">删除</view>
        <view class="card child-card {{activeChildId === item._id ? 'active' : ''}}" style="transform: translateX({{item.offsetX}}px);" data-id="{{item._id}}" data-index="{{index}}" bindtap="selectChild" bindtouchstart="onTouchStart" bindtouchmove="onTouchMove" bindtouchend="onTouchEnd">
          <view class="child-avatar" catchtap="chooseAvatar" data-id="{{item._id}}">
            <image wx:if="{{item.avatarUrl}}" class="avatar-image" src="{{item.avatarUrl}}" mode="aspectFill"></image>
            <text wx:else>{{item.gender === 'girl' ? '花' : '星'}}</text>
          </view>
          <view class="child-info">
            <view class="child-name">{{item.nickname}}</view>
            <view class="muted">{{item.age}} 岁 · {{item.genderText}} · {{item.templateName || '成长'}}</view>
            <view class="avatar-hint">点击头像可上传照片</view>
          </view>
          <button wx:if="{{activeChildId === item._id}}" class="card-action detail-button" hover-class="card-action-hover" catchtap="showTaskDetail" data-id="{{item._id}}" data-name="{{item.nickname}}">任务详情</button>
          <button wx:else class="card-action switch-button" hover-class="card-action-hover" catchtap="selectChild" data-id="{{item._id}}">点击切换</button>
        </view>
      </view>
    </view>

    <view wx:else class="card empty" bindtap="openCreateModal">还没有档案，点左下角加号创建成长空间。</view>
  </view>

  <view class="quick-actions grid-two">
    <button class="secondary-button" bindtap="goTemplates">模板预览</button>
    <button class="secondary-button" bindtap="goSettings">家长设置</button>
  </view>

  <view wx:if="{{showCreateModal}}" class="modal-mask centered" catchtap="closeCreateModal">
    <view class="profile-modal bounce-in" catchtap="noop">
      <view class="modal-title">新增档案</view>
      <view class="form">
        <view class="field-group">
          <view class="field-label">昵称</view>
          <input class="field" maxlength="12" placeholder="可填写昵称" value="{{form.nickname}}" bindinput="onNameInput" />
        </view>
        <view class="field-group">
          <view class="field-label">年龄</view>
          <picker mode="selector" range="{{ages}}" value="{{ageIndex}}" bindchange="onAgeChange">
            <view class="field picker-field">{{form.age}} 岁</view>
          </picker>
        </view>
        <view class="field-group">
          <view class="field-label">性别</view>
          <view class="gender-switch">
            <view class="gender-indicator {{form.gender === 'girl' ? 'right' : 'left'}}"></view>
            <button class="gender-option {{form.gender === 'boy' ? 'active' : ''}}" data-gender="boy" bindtap="chooseGender">男孩</button>
            <button class="gender-option {{form.gender === 'girl' ? 'active' : ''}}" data-gender="girl" bindtap="chooseGender">女孩</button>
          </view>
        </view>
        <button class="primary-button" loading="{{saving}}" bindtap="createProfile">创建</button>
      </view>
    </view>
  </view>

  <view wx:if="{{showTaskModal}}" class="modal-mask centered" catchtap="closeTaskDetail">
    <view class="task-modal bounce-in" catchtap="noop">
      <view class="modal-header">
        <view>
          <view class="modal-title compact">{{taskDetailName}}的任务</view>
          <view class="muted">共 {{taskDetails.length}} 个事项</view>
        </view>
        <button class="close-button" bindtap="closeTaskDetail">×</button>
      </view>
      <view wx:if="{{taskDetails.length}}" class="task-detail-list">
        <view wx:for="{{taskDetails}}" wx:key="_id" class="task-swipe-row">
          <view class="task-actions-menu">
            <button class="task-menu-button edit" data-index="{{index}}" bindtap="openTaskEditor">修改</button>
            <button class="task-menu-button delete" data-index="{{index}}" bindtap="confirmTaskDelete">删除</button>
          </view>
          <view class="task-detail-card" style="transform: translateX({{item.offsetX}}px);" data-index="{{index}}" bindtouchstart="onTaskTouchStart" bindtouchmove="onTaskTouchMove" bindtouchend="onTaskTouchEnd">
            <view class="task-detail-title">{{item.name}}</view>
            <view class="task-detail-desc">{{item.description}}</view>
            <view class="task-meta-row">
              <text>{{item.category}}</text>
              <text>{{item.enabledText}}</text>
            </view>
            <view class="task-meta-row">
              <text>奖励 +{{item.rewardCoins}}</text>
              <text>惩罚 -{{item.penaltyCoins}}</text>
            </view>
            <view class="task-created">创建时间：{{item.createdText}}</view>
          </view>
        </view>
      </view>
      <view wx:else class="empty small-empty">还没有任务信息。</view>
    </view>
  </view>

  <view wx:if="{{showTaskEditor}}" class="modal-mask centered" catchtap="closeTaskEditor">
    <view class="task-editor bounce-in" catchtap="noop">
      <view class="modal-header">
        <view class="modal-title compact">修改任务</view>
        <button class="close-button" bindtap="closeTaskEditor">×</button>
      </view>
      <view class="form">
        <view class="field-group">
          <view class="field-label">任务名称</view>
          <input class="field" maxlength="28" value="{{editTask.name}}" data-field="name" bindinput="onEditTaskInput" />
        </view>
        <view class="field-group">
          <view class="field-label">任务描述</view>
          <textarea class="field textarea compact-textarea" maxlength="80" value="{{editTask.description}}" data-field="description" bindinput="onEditTaskInput"></textarea>
        </view>
        <view class="grid-two">
          <view class="field-group">
            <view class="field-label">奖励金币</view>
            <input class="field" type="number" value="{{editTask.rewardCoins}}" data-field="rewardCoins" bindinput="onEditTaskInput" />
          </view>
          <view class="field-group">
            <view class="field-label">惩罚金币</view>
            <input class="field" type="number" value="{{editTask.penaltyCoins}}" data-field="penaltyCoins" bindinput="onEditTaskInput" />
          </view>
        </view>
        <button class="primary-button" loading="{{taskSaving}}" bindtap="saveTaskEdit">保存修改</button>
      </view>
    </view>
  </view>

  <canvas canvas-id="avatarCanvas" class="avatar-canvas" style="width: 200px; height: 200px;"></canvas>
</view>
