<view class="page">
  <view class="hero">
    <view class="hero-title">金币日历</view>
    <view class="hero-subtitle">看看每天的努力留下了哪些闪光记录。</view>
  </view>

  <view class="mode-switch">
    <view class="mode-indicator {{mode === 'month' ? 'right' : 'left'}}"></view>
    <button class="mode-button {{mode === 'week' ? 'active' : ''}}" data-mode="week" bindtap="switchMode">周视图</button>
    <button class="mode-button {{mode === 'month' ? 'active' : ''}}" data-mode="month" bindtap="switchMode">月视图</button>
  </view>

  <view class="weekday-row">
    <view wx:for="{{weekdays}}" wx:key="*this" class="weekday-label">{{item}}</view>
  </view>

  <view class="calendar-panel {{mode}}" bindtouchstart="onCalendarTouchStart" bindtouchmove="onCalendarTouchMove" bindtouchend="onCalendarTouchEnd">
    <view class="calendar-track" style="transform: translateX(calc(-33.3333% + {{dragOffset}}px)); transition: {{trackTransition}};">
      <view wx:for="{{panels}}" wx:key="key" class="calendar-page">
        <view wx:if="{{mode === 'month'}}" class="month-watermark">{{item.watermarkMonth}}</view>
        <view class="calendar-grid {{mode}}">
          <view wx:for="{{item.days}}" wx:key="date" wx:for-item="day" class="day-cell {{day.isToday ? 'today' : ''}} {{day.date === selectedDate ? 'selected' : ''}} {{day.isFuture ? 'future' : ''}} {{day.isPlaceholder ? 'placeholder' : ''}}" data-date="{{day.date}}" bindtap="selectDay">
            <view class="day-number">{{day.dayLabel}}</view>
            <view wx:if="{{!day.isFuture && !day.isPlaceholder}}" class="{{day.coinClass}}">{{day.total > 0 ? '+' : ''}}{{day.total}}</view>
            <view wx:else class="coin-placeholder"></view>
            <view wx:if="{{day.expenseCount && !day.isPlaceholder}}" class="expense-dot">消费</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section-title">{{selectedDate}} 明细</view>
  <view wx:if="{{selectedTasks.length}}" class="detail-list">
    <view wx:for="{{selectedTasks}}" wx:key="_id" class="card detail-card">
      <view>
        <view class="task-name">{{item.name}}</view>
        <view class="muted">{{item.category}} · {{item.statusText}}</view>
      </view>
      <view class="{{item.amount >= 0 ? 'coin-plus' : 'coin-minus'}}">{{item.amount >= 0 ? '+' : ''}}{{item.amount}}</view>
    </view>
  </view>
  <view wx:else class="card empty">这一天还没有打卡记录。</view>

  <view class="section-title">{{selectedDate}} 消费</view>
  <view wx:if="{{selectedExpenses.length}}" class="detail-list">
    <view wx:for="{{selectedExpenses}}" wx:key="_id" class="card detail-card expense-card">
      <view>
        <view class="task-name">{{item.itemName || item.reason}}</view>
        <view class="muted">金币账本支出</view>
      </view>
      <view class="coin-minus">{{item.amount}}</view>
    </view>
  </view>
  <view wx:else class="card empty">这一天没有消费记录。</view>
</view>
