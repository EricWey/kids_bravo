<view class="page">
  <view class="hero">
    <view class="hero-title">金币日历</view>
    <view class="hero-subtitle">看看每天的努力留下了哪些闪光记录。</view>
  </view>

  <view class="mode-switch">
    <view class="mode-indicator {{mode === 'month' ? 'right' : 'left'}}"></view>
    <button class="{{mode === 'week' ? 'active' : ''}}" data-mode="week" bindtap="switchMode">周视图</button>
    <button class="{{mode === 'month' ? 'active' : ''}}" data-mode="month" bindtap="switchMode">月视图</button>
  </view>

  <view class="weekday-row">
    <view wx:for="{{weekdays}}" wx:key="*this">{{item}}</view>
  </view>

  <view class="calendar-grid {{mode}}">
    <view wx:for="{{days}}" wx:key="date" class="day-cell {{item.isToday ? 'today' : ''}} {{item.date === selectedDate ? 'selected' : ''}} {{item.isFuture ? 'future' : ''}}" data-date="{{item.date}}" bindtap="selectDay">
      <view class="day-number">{{item.day}}</view>
      <view wx:if="{{!item.isFuture}}" class="{{item.total >= 0 ? 'coin-plus' : 'coin-minus'}}">{{item.total >= 0 ? '+' : ''}}{{item.total}}</view>
      <view wx:else class="coin-placeholder"></view>
    </view>
  </view>

  <view class="section-title">{{selectedDate}} 明细</view>
  <view wx:if="{{selectedTasks.length}}" class="detail-list">
    <view wx:for="{{selectedTasks}}" wx:key="_id" class="card detail-card">
      <view>
        <view class="task-name">{{item.name}}</view>
        <view class="muted">{{item.category}} · {{item.statusText}}</view>
      </view>
      <view class="{{item.amount >= 0 ? 'coin-plus' : 'coin-minus'}}">{{item.amount >= 0 ? '+' : ''}}{{item.amount}}</view>
    </view>
  </view>
  <view wx:else class="card empty">这一天还没有打卡记录。</view>
</view>
