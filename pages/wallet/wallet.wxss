.wallet-page {
  padding-bottom: 190rpx;
}

.wallet-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  background: linear-gradient(135deg, #ffdf6b 0%, #ff8f6b 44%, #69d7cc 100%);
}

.coin-badge {
  display: flex;
  width: 132rpx;
  height: 132rpx;
  flex: 0 0 132rpx;
  align-items: center;
  justify-content: center;
  border: 8rpx solid rgba(255, 255, 255, 0.75);
  border-radius: 50%;
  color: #593912;
  background: #ffd24d;
  box-shadow: 0 12rpx 24rpx rgba(142, 83, 25, 0.2);
  font-size: 42rpx;
  font-weight: 900;
  transition: transform 220ms ease, box-shadow 220ms ease;
}

.coin-badge-pop {
  animation: coinBadgePop 780ms ease both;
}

.module-tabs {
  display: grid;
  position: relative;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin: 24rpx 0 4rpx;
  padding: 10rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  align-items: stretch;
}

.module-indicator {
  position: absolute;
  top: 10rpx;
  bottom: 10rpx;
  left: 10rpx;
  width: calc((100% - 44rpx) / 3);
  border-radius: 18rpx;
  background: linear-gradient(135deg, #8de6d6, #ffe05f);
  box-shadow: 0 8rpx 20rpx rgba(63, 173, 156, 0.18);
  transition: transform 240ms ease;
  will-change: transform;
}

.module-indicator.pos-0 {
  transform: translateX(0);
}

.module-indicator.pos-1 {
  transform: translateX(calc(100% + 12rpx));
}

.module-indicator.pos-2 {
  transform: translateX(calc(200% + 24rpx));
}

.module-tab {
  display: flex;
  position: relative;
  z-index: 1;
  min-width: 0;
  height: 76rpx;
  min-height: 76rpx;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  border-radius: 18rpx;
  color: #746250;
  background: transparent;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 76rpx;
  text-align: center;
  transition: color 240ms ease;
}

.module-tab-text {
  display: flex;
  width: 100%;
  text-indent: -150rpx;
  height: 76rpx;
  align-items: center;
  justify-content: center;
  color: inherit;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
}

.module-tab.active {
  color: #2f352f;
}

.module-tab::after {
  border: 0;
}

.chart {
  display: flex;
  height: 260rpx;
  align-items: flex-end;
  justify-content: space-around;
  gap: 12rpx;
}

.bar-wrap {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: #8d7a64;
  font-size: 22rpx;
}

.bar {
  width: 100%;
  min-height: 12rpx;
  max-width: 48rpx;
  border-radius: 999rpx 999rpx 10rpx 10rpx;
}

.positive {
  background: #3cc486;
}

.negative {
  background: #ff7373;
}

.module-panel {
  margin-top: 8rpx;
}

.add-wish-title {
  margin-top: 28rpx;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  border-color: #dff6ff;
  background: rgba(255, 255, 255, 0.96);
}

.picker-field {
  display: flex;
  align-items: center;
  color: #564637;
  line-height: 86rpx;
}

.coin-input-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.coin-input {
  flex: 1;
  min-width: 0;
}

.field-error {
  margin-top: -8rpx;
  color: #d94444;
  font-size: 24rpx;
  font-weight: 800;
}

.wish-photo-icon {
  display: flex;
  overflow: hidden;
  width: 68rpx;
  height: 68rpx;
  flex: 0 0 68rpx;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #9edeea;
  border-radius: 20rpx;
  background: #f0fbff;
  box-shadow: 0 8rpx 18rpx rgba(76, 156, 172, 0.12);
}

.wish-photo-icon.has-photo {
  border-color: #ffd56d;
  background: #fff7df;
}

.wish-photo-thumb {
  width: 100%;
  height: 100%;
}

.camera-glyph {
  position: relative;
  width: 40rpx;
  height: 34rpx;
}

.camera-top {
  position: absolute;
  top: 0;
  left: 10rpx;
  width: 20rpx;
  height: 9rpx;
  border-radius: 7rpx 7rpx 0 0;
  background: #358698;
}

.camera-body {
  display: flex;
  position: absolute;
  bottom: 0;
  left: 0;
  width: 40rpx;
  height: 28rpx;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #358698;
}

.camera-lens {
  width: 14rpx;
  height: 14rpx;
  border: 4rpx solid #f0fbff;
  border-radius: 50%;
}

.form-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.form-actions .primary-button:first-child:last-child {
  grid-column: 1 / -1;
}

.tx-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.wish-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
  padding-bottom: 24rpx;
}

.wish-card {
  display: flex;
  position: relative;
  min-height: 292rpx;
  flex-direction: column;
  align-items: flex-start;
  gap: 16rpx;
  padding: 24rpx;
  border: 4rpx solid #ffe3a8;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.wish-card.done {
  border-color: #aee9d4;
  background: #f2fff9;
}

.wish-card.complete {
  border-color: #f8c233;
  background: linear-gradient(180deg, #fff9dc 0%, #fff2a8 100%);
  box-shadow: 0 8rpx 24rpx rgba(218, 158, 18, 0.28);
}

.wish-card.complete::after {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  color: #ebebea;
  background: #079f37;
  box-shadow: 0 4rpx 12rpx rgba(204, 145, 16, 0.22);
  font-size: 20rpx;
  font-weight: 1000;
  line-height: 40rpx;
  content: '完成';
}

.wish-theme-image {
  width: 112rpx;
  height: 112rpx;
  flex: 0 0 112rpx;
  border-radius: 24rpx;
  background: #f3efe5;
  box-shadow: 0 8rpx 18rpx rgba(95, 72, 38, 0.1);
}

.wish-photo-chip {
  position: absolute;
  left: 92rpx;
  top: 92rpx;
  width: 46rpx;
  height: 46rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  background: #fff7df;
}

.wish-content {
  width: 100%;
  flex: none;
  min-width: 0;
  padding-right: 92rpx;
}

.wish-name,
.tx-title,
.exchange-name {
  color: #443423;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.3;
}

.wish-name {
  display: -webkit-box;
  overflow: hidden;
  margin-bottom: 12rpx;
  min-height: 74rpx;
  padding-right: 0;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  font-size: 28rpx;
}

.coin-pill {
  display: inline-flex;
  min-height: 48rpx;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #5f3c0c;
  background: #ffe192;
  font-size: 23rpx;
  font-weight: 900;
}

.progress-text {
  margin-top: 10rpx;
  color: #7a6956;
  font-size: 23rpx;
  font-weight: 800;
}

.progress-ring {
  display: flex;
  position: absolute;
  right: 16rpx;
  top: 50%;
  width: 78rpx;
  height: 78rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: conic-gradient(#52c7b8 0%, #eef1e7 0);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.8);
  transform: translateY(-50%);
  transition: background 260ms ease, box-shadow 260ms ease, transform 260ms ease;
}

.progress-ring::after {
  position: absolute;
  inset: 12rpx;
  border-radius: 50%;
  background: #ffffff;
  transition: opacity 220ms ease, background 220ms ease, transform 220ms ease;
  content: '';
}

.progress-percent {
  position: relative;
  z-index: 1;
  color: #34796f;
  font-size: 20rpx;
  font-weight: 1000;
  line-height: 1;
  text-align: center;
  transition: opacity 220ms ease, transform 220ms ease, color 220ms ease;
}

.progress-check {
  position: relative;
  z-index: 1;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 1000;
  line-height: 1;
  transform: scale(0.92);
  animation: checkPop 260ms ease both;
}

.progress-ring.complete {
  background: #22b573;
  box-shadow: 0 8rpx 18rpx rgba(34, 181, 115, 0.28);
  transform: translateY(-50%) scale(1.04);
}

.progress-ring.complete::after {
  opacity: 0;
  transform: scale(0.35);
}

.progress-ring.p0 {
  background: conic-gradient(#52c7b8 0%, #eef1e7 0);
}

.progress-ring.p10 {
  background: conic-gradient(#52c7b8 10%, #eef1e7 0);
}

.progress-ring.p20 {
  background: conic-gradient(#52c7b8 20%, #eef1e7 0);
}

.progress-ring.p30 {
  background: conic-gradient(#52c7b8 30%, #eef1e7 0);
}

.progress-ring.p40 {
  background: conic-gradient(#52c7b8 40%, #eef1e7 0);
}

.progress-ring.p50 {
  background: conic-gradient(#52c7b8 50%, #eef1e7 0);
}

.progress-ring.p60 {
  background: conic-gradient(#52c7b8 60%, #eef1e7 0);
}

.progress-ring.p70 {
  background: conic-gradient(#52c7b8 70%, #eef1e7 0);
}

.progress-ring.p80 {
  background: conic-gradient(#52c7b8 80%, #eef1e7 0);
}

.progress-ring.p90 {
  background: conic-gradient(#52c7b8 90%, #eef1e7 0);
}

.progress-ring.p100 {
  background: #22b573;
}

@keyframes checkPop {
  0% {
    opacity: 0;
    transform: scale(0.72);
  }
  70% {
    opacity: 1;
    transform: scale(1.12);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.wish-action-backdrop {
  z-index: 70;
}

.wish-action-modal {
  width: min(640rpx, 100%);
  max-width: 100%;
  align-items: center;
  overflow: hidden;
  text-align: center;
}

.wish-action-icon {
  display: flex;
  width: 96rpx;
  height: 96rpx;
  align-items: center;
  justify-content: center;
  border: 6rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  color: #5f3c0c;
  background: linear-gradient(135deg, #ffe176, #8de6d6);
  box-shadow: 0 10rpx 22rpx rgba(63, 173, 156, 0.2);
  font-size: 38rpx;
  font-weight: 1000;
}

.wish-action-name {
  display: -webkit-box;
  overflow: hidden;
  width: 100%;
  color: #443423;
  font-size: 30rpx;
  font-weight: 1000;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.wish-action-actions {
  display: flex;
  width: 100%;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.wish-action-button {
  width: 100%;
  min-width: 0;
  min-height: 80rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  line-height: 1;
  white-space: nowrap;
}

.modal-backdrop {
  display: flex;
  position: fixed;
  inset: 0;
  z-index: 50;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(54, 45, 34, 0.36);
}

.edit-modal {
  display: flex;
  width: 100%;
  max-width: 640rpx;
  flex-direction: column;
  gap: 18rpx;
  padding: 34rpx;
  border: 4rpx solid #dff6ff;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.16);
  animation: modalIn 180ms ease both;
}

.edit-title {
  color: #443423;
  font-size: 32rpx;
  font-weight: 1000;
}

@keyframes menuPop {
  to {
    opacity: 1;
    transform: translateX(-50%) scale(1);
  }
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: translateY(18rpx) scale(0.96);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.mini-button {
  min-width: 106rpx;
  min-height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #276c7a;
  background: #ddf7ff;
  font-size: 23rpx;
  font-weight: 900;
}

.mini-button.danger {
  color: #9b3333;
  background: #ffe0df;
}

.filter-row {
  display: grid;
  grid-template-columns: 1fr 1fr 104rpx;
  gap: 12rpx;
  margin: 20rpx 0;
}

.filter-chip,
.filter-clear {
  display: flex;
  min-height: 66rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #5e5144;
  background: #fff5d7;
  font-size: 24rpx;
  font-weight: 900;
}

.filter-clear {
  color: #2f7181;
  background: #def8ff;
}

.tx-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.tx-photo {
  width: 104rpx;
  height: 104rpx;
  flex: 0 0 104rpx;
  border-radius: 18rpx;
  background: #f3efe5;
}

.tx-main {
  flex: 1;
  min-width: 0;
}

.tx-card .coin-minus {
  flex: 0 0 auto;
  font-size: 34rpx;
  font-weight: 1000;
}

.exchange-group {
  margin-top: 26rpx;
}

.exchange-manage-title {
  margin-top: 34rpx;
}

.group-title {
  margin: 0 4rpx 14rpx;
  color: #4b3b2d;
  font-size: 28rpx;
  font-weight: 900;
}

.exchange-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
}

.exchange-card {
  display: flex;
  position: relative;
  min-height: 310rpx;
  flex-direction: column;
  align-items: flex-start;
  gap: 16rpx;
  padding: 24rpx;
  border: 4rpx solid #d8f3e7;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  transition: border-color 220ms ease, box-shadow 220ms ease, transform 220ms ease, background 220ms ease;
}

.exchange-card::after {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #8de6d6;
  box-shadow: 0 0 0 8rpx rgba(141, 230, 214, 0.18);
  content: '';
}

.exchange-card.redeemed {
  border-color: #22b573;
  background: #f2fff9;
  box-shadow: 0 10rpx 26rpx rgba(34, 181, 115, 0.24);
  transform: scale(1.02);
}

.exchange-card.redeemed::after {
  background: #22b573;
  box-shadow: 0 0 0 8rpx rgba(34, 181, 115, 0.18);
}

.exchange-theme-image {
  width: 112rpx;
  height: 112rpx;
  flex: 0 0 112rpx;
  border-radius: 24rpx;
  background: #f3efe5;
  box-shadow: 0 8rpx 18rpx rgba(95, 72, 38, 0.1);
}

.exchange-body {
  width: 100%;
  min-width: 0;
}

.exchange-desc {
  display: -webkit-box;
  overflow: hidden;
  min-height: 64rpx;
  margin-top: 12rpx;
  color: #7a6956;
  font-size: 23rpx;
  line-height: 1.4;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.exchange-name {
  display: -webkit-box;
  overflow: hidden;
  min-height: 72rpx;
  margin-bottom: 12rpx;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  font-size: 28rpx;
}

.preset-tag {
  display: inline-flex;
  min-height: 44rpx;
  align-items: center;
  margin-top: 14rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #7f5d0c;
  background: #fff0be;
  font-size: 22rpx;
  font-weight: 900;
}

.exchange-confirm-backdrop {
  z-index: 70;
}

.exchange-confirm-modal {
  width: min(640rpx, 100%);
  max-width: 100%;
  align-items: center;
  overflow: hidden;
  text-align: center;
}

.exchange-confirm-icon {
  display: flex;
  width: 96rpx;
  height: 96rpx;
  align-items: center;
  justify-content: center;
  border: 6rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  color: #5f3c0c;
  background: linear-gradient(135deg, #ffe176, #ffb84f);
  box-shadow: 0 10rpx 22rpx rgba(164, 101, 18, 0.2);
  font-size: 38rpx;
  font-weight: 1000;
}

.exchange-confirm-name {
  color: #443423;
  font-size: 32rpx;
  font-weight: 1000;
  line-height: 1.3;
}

.exchange-confirm-cost {
  display: inline-flex;
  min-height: 58rpx;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: #5f3c0c;
  background: #ffe192;
  font-size: 26rpx;
  font-weight: 1000;
}

.exchange-confirm-tip {
  color: #7a6956;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.45;
}

.exchange-confirm-actions {
  display: flex;
  width: 100%;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.exchange-confirm-button {
  width: auto;
  min-width: 0;
  min-height: 80rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  line-height: 1;
  white-space: nowrap;
}

@media (max-width: 340px) {
  .wish-action-actions,
  .exchange-confirm-actions {
    grid-template-columns: 1fr;
  }

  .wish-action-button,
  .exchange-confirm-button {
    min-height: 76rpx;
  }
}

.coin-spin-layer {
  display: flex;
  position: fixed;
  inset: 0;
  z-index: 90;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.coin-spin-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 26rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 44rpx rgba(98, 65, 19, 0.2);
  animation: coinFloat 980ms ease both;
}

.spinning-coin {
  display: flex;
  width: 104rpx;
  height: 104rpx;
  align-items: center;
  justify-content: center;
  border: 8rpx solid rgba(255, 255, 255, 0.76);
  border-radius: 50%;
  color: #5f3c0c;
  background: radial-gradient(circle at 32% 28%, #fff7b3 0%, #ffd24d 48%, #f6a92e 100%);
  box-shadow: inset 0 -8rpx 0 rgba(174, 103, 20, 0.12), 0 10rpx 20rpx rgba(155, 92, 21, 0.2);
  font-size: 34rpx;
  font-weight: 1000;
  animation: coinSpin 780ms cubic-bezier(0.24, 0.72, 0.28, 1) both;
}

.coin-delta {
  color: #ff7373;
  font-size: 40rpx;
  font-weight: 1000;
  line-height: 1;
  animation: deltaPop 780ms ease both;
}

@keyframes coinBadgePop {
  0% {
    transform: scale(1);
  }
  28% {
    transform: scale(1.14) rotate(-4deg);
    box-shadow: 0 16rpx 30rpx rgba(142, 83, 25, 0.26);
  }
  64% {
    transform: scale(0.96) rotate(3deg);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes coinFloat {
  0% {
    opacity: 0;
    transform: translateY(40rpx) scale(0.86);
  }
  18% {
    opacity: 1;
  }
  72% {
    opacity: 1;
    transform: translateY(-12rpx) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(-34rpx) scale(0.96);
  }
}

@keyframes coinSpin {
  0% {
    transform: rotateY(0deg) scale(0.72);
  }
  45% {
    transform: rotateY(540deg) scale(1.12);
  }
  100% {
    transform: rotateY(1080deg) scale(1);
  }
}

@keyframes deltaPop {
  0% {
    opacity: 0;
    transform: translateY(12rpx) scale(0.82);
  }
  32% {
    opacity: 1;
    transform: translateY(0) scale(1.08);
  }
  100% {
    opacity: 0;
    transform: translateY(-20rpx) scale(1);
  }
}

.hidden-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 960px;
  height: 960px;
}
