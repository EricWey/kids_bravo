.pin-panel,
.edit-area {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.top-actions {
  display: flex;
  grid-template-columns: repeat(2, auto);
  gap: 16rpx;

}

.action-button {
  min-width:0;
  width: auto;
  padding:12rpx;
}

.edit-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.picker-field {
  display: flex;
  align-items: center;
}

.compact-description {
  height: 150rpx;
  min-height: 66rpx;
  padding-top: 10rpx;
  padding-bottom: 10rpx;
  line-height: 1.25;
}

.status-switch-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.task-status-control.inline {
  justify-content: flex-start;
}

.small {
  min-width: 150rpx;
  min-height: 66rpx;
  font-size: 24rpx;
}

.modal-mask {
  display: flex;
  position: fixed;
  inset: 0;
  z-index: 120;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(55, 42, 23, 0.34);
}

.task-modal {
  position: relative;
  width: 100%;
  max-width: 650rpx;
  max-height: calc(100vh - 128rpx);
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fffdf5;
  box-shadow: 0 18rpx 50rpx rgba(60, 39, 12, 0.18);
}

.close-button {
  display: flex;
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  z-index: 2;
  width: 52rpx;
  height: 52rpx;
  align-items: center;
  justify-content: center;
  color: #8d7760;
  font-size: 38rpx;
  font-weight: 900;
}

.modal-title {
  margin-bottom: 24rpx;
  padding-right: 56rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.modal-actions {
  display:flex;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}
