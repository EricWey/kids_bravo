.celebration-layer,
.encourage-layer {
  position: fixed;
  inset: 0;
  z-index: 150;
  pointer-events: none;
}

.confetti {
  position: absolute;
  bottom: -36rpx;
  width: 18rpx;
  height: 30rpx;
  border-radius: 6rpx;
  background: #ffcf5a;
  animation: confettiUp 1500ms ease-out both;
}

.piece-0 { left: 12%; background: #ff6b6b; animation-delay: 0ms; }
.piece-1 { left: 18%; background: #45c4b0; animation-delay: 80ms; }
.piece-2 { left: 25%; background: #ffcf5a; animation-delay: 140ms; }
.piece-3 { left: 33%; background: #53a7ff; animation-delay: 20ms; }
.piece-4 { left: 42%; background: #ff8a3d; animation-delay: 100ms; }
.piece-5 { left: 50%; background: #72dc7a; animation-delay: 40ms; }
.piece-6 { left: 58%; background: #ff6bcb; animation-delay: 120ms; }
.piece-7 { left: 67%; background: #45c4b0; animation-delay: 70ms; }
.piece-8 { left: 76%; background: #ffcf5a; animation-delay: 150ms; }
.piece-9 { left: 86%; background: #53a7ff; animation-delay: 30ms; }

@keyframes confettiUp {
  0% {
    opacity: 0;
    transform: translateY(0) rotate(0deg) scale(0.8);
  }
  12% {
    opacity: 1;
  }
  100% {
    opacity: 0;
    transform: translateY(-78vh) rotate(540deg) scale(1.1);
  }
}

.encourage-layer {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  pointer-events: auto;
  background: rgba(55, 42, 23, 0.34);
}

.encourage-dialog {
  width: min(600rpx, 100%);
  padding: 36rpx 32rpx 32rpx;
  border-radius: 28rpx;
  color: #493d31;
  text-align: center;
  background: #fffdf5;
  box-shadow: 0 18rpx 50rpx rgba(60, 39, 12, 0.18);
  animation: encourageDialogIn 240ms ease both;
}

.encourage-face {
  font-size: 64rpx;
  line-height: 1;
}

.encourage-title {
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.encourage-text {
  margin-top: 12rpx;
  color: #7e6c5c;
  font-size: 26rpx;
  line-height: 1.45;
}

.encourage-close {
  margin-top: 28rpx;
}

@keyframes encourageDialogIn {
  0% {
    opacity: 0;
    transform: translateY(28rpx) scale(0.94);
  }
  70% {
    opacity: 1;
    transform: translateY(-4rpx) scale(1.02);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes resetPop {
  0% {
    opacity: 0;
    transform: translateY(-12rpx) scale(0.9);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
