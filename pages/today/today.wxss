.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 26rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-avatar-button {
  display: flex;
  width: 132rpx;
  height: 132rpx;
  flex: 0 0 132rpx;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 5rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 50%;
  background: linear-gradient(135deg, #45c4b0, #53a7ff);
  box-shadow: 0 12rpx 28rpx rgba(60, 39, 12, 0.16);
  transition: transform 140ms ease, filter 140ms ease;
}

.hero-avatar-button-hover {
  transform: scale(0.95);
  filter: brightness(0.98);
}

.hero-avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.hero-avatar-placeholder {
  color: #fff;
  font-size: 46rpx;
  font-weight: 900;
}

.action-row {
  margin: 24rpx 0 8rpx;
}

.action-button {
  flex: 1;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.task-card {
  display: flex;
  position: relative;
  overflow: hidden;
  transition: transform 180ms ease, border-color 180ms ease, filter 220ms ease, opacity 220ms ease;
}

.task-card.done {
  border-color: #87dfa7;
}

.task-card.missed {
  border-color: #ffb0a8;
}

.task-card.checked {
  opacity: 1;
}

.task-content {
  display: flex;
  width: 100%;
  flex-direction: column;
  gap: 18rpx;
  transition: filter 220ms ease, opacity 220ms ease;
}

.reset-button {
  display: flex;
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  z-index: 2;
  min-width: 30rpx;
  min-height: 54rpx;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff7d6;
  border-radius: 999rpx;
  color: #5a3a10;
  font-size: 24rpx;
  font-weight: 900;
  background: #ffcf5a;
  box-shadow: 0 8rpx 20rpx rgba(89, 58, 16, 0.16);
  animation: resetPop 220ms ease both;
}

.reset-button-hover {
  transform: scale(0.94);
}

.task-main {
  width: 100%;
  min-width: 0;
}

.task-name {
  font-size: 31rpx;
  font-weight: 900;
}

.task-desc {
  margin-top: 8rpx;
  color: #7e6c5c;
  font-size: 25rpx;
  line-height: 1.4;
}

.coin-line {
  display: flex;
  gap: 52rpx;
  margin-top: 14rpx;
  font-size: 24rpx;
  font-weight: 800;
}

/* 1. 按钮外层容器：修复原布局冲突，改为弹性布局，控制整体宽度/间距 */
.task-actions {
  display: flex;
  justify-content: center;
  align-items: stretch;
  column-gap: 0; /* 关键：取消两个按钮之间的间距，实现无缝连体 */
  width: 100%;
  margin-top: 10rpx;
}

/* 2. 按钮公共基础样式：统一长条、字体、过渡，彻底抛弃圆形 */
.checkin-icon-button {
  /* 取消原有圆形宽高 */
  width: auto;
  height: 76rpx; /* 长条按钮高度，可自行微调 70~85rpx */
  flex: 1; /* 两个按钮均分宽度 */
  display: flex;
  align-items: center;
  justify-content: center;
  border: none; /* 取消原有边框 */
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1;
  white-space: nowrap;
  box-shadow:  0 4rpx 12rpx rgba(0,0,0,0.06);

  /* 统一过渡动画 */
  transition: transform 120ms ease, filter 120ms ease, background 180ms ease;
}

/* ========== 核心：左右按钮单独设置圆角，实现连体效果 ========== */
/* 左侧【完成】按钮：只保留 左上、左下 圆角 */
.done-button {
  font-size: 50rpx;
  border-radius: 999rpx 0 0 999rpx;
  background: #bbefde; /* 浅绿底色（常态） */
  color: #2f8c72;
}

/* 右侧【未完成】按钮：只保留 右上、右下 圆角 */
.miss-button {
  border-radius: 0 999rpx 999rpx 0;
  background: #f4e4e4; /* 浅红底色（常态） */
  color: #d94444;
}

/* ========== 点击按压效果（保留原有交互手感） ========== */
.miss-button-hover {
  transform: scale(0.98);
  filter: brightness(0.94);
  background: #ff7373;
  color: #ffffff;
}
.done-button-hover {
  transform: scale(0.98);
  filter: brightness(0.94);
  background: #45c4b0;
  color: #ffffff;
}

/* ========== 禁用状态（原有逻辑保留，灰化） ========== */
.checkin-icon-button.selected {
  transform: translateY(-2rpx);
  box-shadow: 0 10rpx 24rpx rgba(60, 39, 12, 0.14);
}

.done-button.selected {
  background: #45c4b0;
  color: #ffffff;
}

.miss-button.selected {
  background: #ff7373;
  color: #ffffff;
}

.checkin-icon-button.muted {
  opacity: 0.42;
  box-shadow: none;
}

.done-button.disabled,
.miss-button.disabled {
  pointer-events: none; /* 禁用后不可点击 */
}

